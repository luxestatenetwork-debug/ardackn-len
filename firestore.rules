rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection and all nested sub‑collections
    match /users/{uid} {
      allow read, write: if request.auth != null; // temporary test rule
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null; // temporary test rule for sub‑collections
    }
  }
}
